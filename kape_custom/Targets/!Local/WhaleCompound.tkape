        FileMask: Last Session
    -
        Name: Whale Last Tabs
        Category: Communications
        Path: C:\Users\%user%\AppData\Local\Naver\Naver Whale\User Data\*\
        FileMask: Last Tabs
    -
        Name: Whale Sessions Folder
        Category: Communications
        Path: C:\Users\%user%\AppData\Local\Naver\Naver Whale\User Data\*\Sessions\
        Recursive: false
    -
        Name: Whale Login Data
        Category: Communications
        Path: C:\Users\%user%\AppData\Local\Naver\Naver Whale\User Data\*\
        FileMask: Login Data*
    -
        Name: Whale Media History
        Category: Communications
        Path: C:\Users\%user%\AppData\Local\Naver\Naver Whale\User Data\*\
        FileMask: Media History*
