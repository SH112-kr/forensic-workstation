    -
        Name: Whale Network Persistent State (Network subfolder)
        Category: Communications
        Path: C:\Users\%user%\AppData\Local\Naver\Naver Whale\User Data\*\Network
        FileMask: Network Persistent State
    -
        Name: Whale Preferences
        Category: Communications
        Path: C:\Users\%user%\AppData\Local\Naver\Naver Whale\User Data\*\
        FileMask: Preferences
    -
        Name: Whale Quota Manager
        Category: Communications
        Path: C:\Users\%user%\AppData\Local\Naver\Naver Whale\User Data\*\
        FileMask: QuotaManager*
    -
        Name: Whale Quota Manager (WebStorage subfolder)
        Category: Communications
        Path: C:\Users\%user%\AppData\Local\Naver\Naver Whale\User Data\*\WebStorage
