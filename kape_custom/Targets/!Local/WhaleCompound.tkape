Description: Whale Compound
Author: JaeheonKim
Version: 1.0
Id: 44d942ab-c7c7-4c26-8cbc-a0c4b0dffdaf
RecreateDirectories: true
Targets:
    # ============================================================
    # Whale Browser Artifacts
    # ============================================================
    -
        Name: Whale Bookmarks
        Category: Communications
        Path: C:\Users\%user%\AppData\Local\Naver\Naver Whale\User Data\*\
        FileMask: Bookmarks*
    -
        Name: Whale Cookies
        Category: Communications
        Path: C:\Users\%user%\AppData\Local\Naver\Naver Whale\User Data\*\Network
        FileMask: Cookies*
    -
        Name: Whale Current Session
        Category: Communications
        Path: C:\Users\%user%\AppData\Local\Naver\Naver Whale\User Data\*\
        FileMask: Current Session
    -
        Name: Whale Current Tabs
        Category: Communications
        Path: C:\Users\%user%\AppData\Local\Naver\Naver Whale\User Data\*\
        FileMask: Current Tabs
    -
        Name: Whale Download Metadata
        Category: Communications
        Path: C:\Users\%user%\AppData\Local\Naver\Naver Whale\User Data\*\
        FileMask: DownloadMetadata
    -
        Name: Whale Extension Cookies
        Category: Communications
        Path: C:\Users\%user%\AppData\Local\Naver\Naver Whale\User Data\*\
        FileMask: Extension Cookies*
    -
        Name: Whale Favicons
        Category: Communications
        Path: C:\Users\%user%\AppData\Local\Naver\Naver Whale\User Data\*\
        FileMask: Favicons*
    -
        Name: Whale History
        Category: Communications
        Path: C:\Users\%user%\AppData\Local\Naver\Naver Whale\User Data\*\
