# Ghidra installation directory (required for binary analysis)
# FORENSIC_GHIDRA_INSTALL_DIR=C:/Tools/ghidra_11.3_PUBLIC

# KAPE executable path (auto-detected if empty)
# FORENSIC_KAPE_PATH=C:/Tools/KAPE/kape.exe

# Hayabusa executable path (default: searches PATH)
# FORENSIC_HAYABUSA_PATH=hayabusa

# API Keys for threat intelligence (optional)
# FORENSIC_OTX_API_KEY=
# FORENSIC_ABUSEIPDB_API_KEY=

# Server port (default: 8001)
# PORT=8001
